<Window x:Class="SteamowoClient.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steamowo - Logowanie" Height="500" Width="380"
        Background="{StaticResource TloBrush}"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock Text="STEAMOWO" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AkcentBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Login" Foreground="{StaticResource TekstBrush}" Margin="0,5,0,2"/>
        <TextBox x:Name="TxtLogin" Padding="5" />

        <TextBlock Text="Email (tylko przy rejestracji)" Foreground="{StaticResource TekstBrush}" Margin="0,10,0,2"/>
        <TextBox x:Name="TxtEmail" Padding="5" />

        <TextBlock Text="Haslo" Foreground="{StaticResource TekstBrush}" Margin="0,10,0,2"/>
        <PasswordBox x:Name="TxtHaslo" Padding="5" />

        <TextBlock Text="Powtorz haslo (tylko przy rejestracji)" Foreground="{StaticResource TekstBrush}" Margin="0,10,0,2"/>
        <PasswordBox x:Name="TxtHasloPowtorz" Padding="5" />

        <TextBlock x:Name="TxtKomunikat" Foreground="{StaticResource BladBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <Button x:Name="BtnZaloguj" Content="Zaloguj sie" Margin="0,15,0,5" Padding="5" Click="BtnZaloguj_Click"/>
        <Button x:Name="BtnZarejestruj" Content="Zarejestruj nowe konto" Padding="5" Click="BtnZarejestruj_Click"/>
    </StackPanel>
</Window>
