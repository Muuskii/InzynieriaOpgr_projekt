<Window x:Class="SteamowoClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steamowo" Height="650" Width="1000"
        Background="{StaticResource TloBrush}"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Gorny pasek: info o koncie i saldo -->
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}" Padding="10">
            <Grid>
                <TextBlock x:Name="TxtWitaj" Foreground="{StaticResource TekstBrush}" FontSize="16" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="TxtSaldo" Foreground="{StaticResource AkcentBrush}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="BtnDoladuj" Content="Doladuj +50 zl" Padding="5" Click="BtnDoladuj_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="Zakladki" SelectionChanged="Zakladki_SelectionChanged">
            <TabItem Header="Sklep">
                <Grid Margin="10">
                    <ListView x:Name="ListaSklep">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Okladka" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding UrlOkladki}" Height="50" Width="50" Stretch="UniformToFill"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Tytul" Width="220" DisplayMemberBinding="{Binding Tytul}"/>
                                <GridViewColumn Header="Gatunek" Width="130" DisplayMemberBinding="{Binding Gatunek}"/>
                                <GridViewColumn Header="Producent" Width="140" DisplayMemberBinding="{Binding Producent}"/>
                                <GridViewColumn Header="Cena" Width="80" DisplayMemberBinding="{Binding Cena, StringFormat={}{0:0.00} zl}"/>
                                <GridViewColumn Header="" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Kup" Padding="5,2" Click="BtnKup_Click" Tag="{Binding Id}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <TabItem Header="Moja biblioteka">
                <Grid Margin="10">
                    <ListView x:Name="ListaBiblioteka">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Okladka" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding UrlOkladki}" Height="50" Width="50" Stretch="UniformToFill"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Tytul" Width="200" DisplayMemberBinding="{Binding Tytul}"/>
                                <GridViewColumn Header="Gatunek" Width="130" DisplayMemberBinding="{Binding Gatunek}"/>
                                <GridViewColumn Header="Data zakupu" Width="130" DisplayMemberBinding="{Binding DataZakupu, StringFormat=d}"/>
                                <GridViewColumn Header="Czas gry (h)" Width="100" DisplayMemberBinding="{Binding CzasGry}"/>
                                <GridViewColumn Header="" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Zwroc" Padding="5,2" Click="BtnZwroc_Click" Tag="{Binding GameId}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <TabItem Header="Historia transakcji">
                <Grid Margin="10">
                    <ListView x:Name="ListaHistoria">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Data" Width="150" DisplayMemberBinding="{Binding Data, StringFormat='g'}"/>
                                <GridViewColumn Header="Typ" Width="120" DisplayMemberBinding="{Binding Typ}"/>
                                <GridViewColumn Header="Kwota" Width="100" DisplayMemberBinding="{Binding Kwota, StringFormat={}{0:0.00} zl}"/>
                                <GridViewColumn Header="Opis" Width="350" DisplayMemberBinding="{Binding Opis}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <TabItem x:Name="ZakladkaAdmin" Header="Panel admina" Visibility="Collapsed">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Dodaj / edytuj gre (zaznacz wiersz ponizej, zeby edytowac)" Foreground="{StaticResource TekstBrush}" Margin="0,0,0,8"/>
                            <UniformGrid Columns="4" Rows="2">
                                <StackPanel Margin="0,0,10,5">
                                    <TextBlock Text="Tytul" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtATytul" Padding="4"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,5">
                                    <TextBlock Text="Producent" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtAProducent" Padding="4"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,5">
                                    <TextBlock Text="Gatunek" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtAGatunek" Padding="4"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,5">
                                    <TextBlock Text="Cena" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtACena" Padding="4"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Opis" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtAOpis" Padding="4"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="URL okladki" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtAOkladka" Padding="4"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Data wydania (rrrr-mm-dd)" Foreground="{StaticResource TekstBrush}" FontSize="11"/>
                                    <TextBox x:Name="TxtAData" Padding="4"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom">
                                    <Button Content="Wyczysc formularz" Padding="5" Click="BtnAWyczysc_Click"/>
                                </StackPanel>
                            </UniformGrid>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Dodaj nowa gre" Padding="8,4" Margin="0,0,10,0" Click="BtnADodaj_Click"/>
                                <Button Content="Zapisz zmiany (edycja)" Padding="8,4" Margin="0,0,10,0" Click="BtnAZapisz_Click"/>
                                <Button Content="Usun zaznaczona" Padding="8,4" Click="BtnAUsun_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ListView x:Name="ListaAdmin" Grid.Row="1" SelectionChanged="ListaAdmin_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Id" Width="40" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Tytul" Width="200" DisplayMemberBinding="{Binding Tytul}"/>
                                <GridViewColumn Header="Gatunek" Width="120" DisplayMemberBinding="{Binding Gatunek}"/>
                                <GridViewColumn Header="Producent" Width="140" DisplayMemberBinding="{Binding Producent}"/>
                                <GridViewColumn Header="Cena" Width="80" DisplayMemberBinding="{Binding Cena, StringFormat={}{0:0.00} zl}"/>
                                <GridViewColumn Header="Data wydania" Width="100" DisplayMemberBinding="{Binding DataWydania, StringFormat=d}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
